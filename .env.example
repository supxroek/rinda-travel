# .env.example
# Rinda Travel — Environment Variables Template
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://username:password@host:5432/rinda_travel?schema=public"

# ============================================================
# BETTER AUTH
# ============================================================
BETTER_AUTH_SECRET="your-secret-key-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# ============================================================
# SUPABASE
# ============================================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ============================================================
# CLOUDINARY (Optional)
# ============================================================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ============================================================
# EMAIL (Resend)
# ============================================================
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="noreply@rindatravel.com"
EMAIL_TO="contact@rindatravel.com"

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Rinda Travel"
NODE_ENV="development"
